---
import Layout from '@/layouts/Layout.astro';
import { LISTENING_LIST } from '@/constants/listening';

// 將清單依照日期由新到舊 (Descending) 排序
const sortedListening = [...LISTENING_LIST].sort((a, b) => {
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// 格式化日期為好閱讀的英文格式 (如: Feb 27, 2026)
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
};
---

<Layout title="Listening Practice" description="Curated listening materials and YouTube videos.">
  
  <div class="fixed top-[-20%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-indigo-100/50 blur-[120px] rounded-full pointer-events-none -z-10"></div>

  <div class="max-w-4xl mx-auto w-full px-5 md:px-8">
    
    <header class="text-center mb-12 md:mb-16 animate-fade-in-up">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-800 mb-4">
        Listening Practice
      </h1>
      <div class="mt-6 flex justify-center gap-4 text-xs font-bold uppercase tracking-wider text-slate-400">
        <span>Total Tracks: {sortedListening.length}</span>
      </div>
    </header>

    <div class="flex flex-col gap-4 pb-24">
      {sortedListening.map((item, index) => (
        <a 
          href={item.href} 
          target="_blank" 
          rel="noopener noreferrer"
          class="group relative flex items-center justify-between p-5 md:p-6 bg-white border border-slate-200 rounded-2xl shadow-sm hover:shadow-lg hover:border-indigo-300 hover:-translate-y-1 transition-all duration-300 animate-fade-in-up"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <div class="flex items-center gap-5 md:gap-6 w-full">
            
            <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-full bg-indigo-50 text-indigo-500 group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 ml-1">
                <path d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" />
              </svg>
            </div>
            
            <div class="flex flex-col flex-1 min-w-0">
              <h2 class="text-lg md:text-xl font-bold text-slate-800 group-hover:text-indigo-600 transition-colors duration-300 truncate">
                {item.name}
              </h2>
              <div class="flex items-center gap-3 mt-1.5">
                <span class="text-[11px] md:text-xs font-mono text-slate-500 bg-slate-100 px-2 py-0.5 rounded border border-slate-200/60">
                  {formatDate(item.date)}
                </span>
                <span class="text-[10px] md:text-xs font-bold text-rose-500 uppercase tracking-widest bg-rose-50 px-2 py-0.5 rounded border border-rose-100">
                  YouTube
                </span>
              </div>
            </div>
          </div>

          <div class="flex-shrink-0 hidden sm:flex items-center justify-center w-10 h-10 ml-4 rounded-full border border-slate-100 text-slate-300 group-hover:border-indigo-200 group-hover:text-indigo-600 group-hover:bg-indigo-50 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</Layout>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { 
    animation: fade-in-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; 
    opacity: 0; 
  }
</style>