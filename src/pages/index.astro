---
import Layout from '@/layouts/Layout.astro';
import { useVocabulary } from '@/utils/useVocabulary';

const commonVocab = await useVocabulary('common');
const toeflVocab = await useVocabulary('toefl');
const allVocab = [...commonVocab, ...toeflVocab];
const totalWords = allVocab.length;

// 取前 50 大高頻單字傳給前端輪播
const topVocabs = allVocab
  .sort((a, b) => b.frequency - a.frequency)
  .slice(0, 50)
  .map(v => ({
    word: v.word,
    phonetic: v.phonetic,
    pos: v.occurrences[0]?.pos || '',
    meaning: v.occurrences[0]?.meaning || '',
    example: v.occurrences[0]?.example || ''
  }));
---

<Layout title="Home">
  <main class="fixed inset-0 w-full h-[100dvh] bg-slate-50 text-slate-800 overflow-hidden font-sans selection:bg-indigo-100 selection:text-indigo-900 flex flex-col items-center justify-center">
    
    <div class="absolute inset-0 z-0 opacity-40 pointer-events-none" style="background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px;"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-indigo-200/40 blur-[100px] rounded-full mix-blend-multiply pointer-events-none"></div>
    <div class="absolute bottom-[-10%] right-[-5%] w-[600px] h-[600px] bg-sky-200/30 blur-[120px] rounded-full mix-blend-multiply pointer-events-none"></div>

    <div id="vocab-data" data-words={JSON.stringify(topVocabs)} class="hidden"></div>

    <div id="hero-container" class="relative z-10 flex flex-col items-center justify-center w-full max-w-4xl px-6 text-center opacity-0 translate-y-8 transition-all duration-1000 ease-out">
      
      <div class="text-sm font-bold text-indigo-500 tracking-[0.3em] uppercase mb-6 md:mb-8 flex items-center gap-3">
        <span class="w-8 h-px bg-indigo-200"></span>
        Featured Words
        <span class="w-8 h-px bg-indigo-200"></span>
      </div>

      <div id="vocab-content-wrapper" class="flex flex-col items-center transition-all duration-500 transform">
        <div class="flex items-center justify-center gap-4 md:gap-6 mb-4">
          <h1 id="featured-word" class="text-5xl md:text-7xl xl:text-8xl font-black tracking-tight text-slate-800 capitalize drop-shadow-sm">
            </h1>
          <button 
            id="tts-btn"
            class="flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-white border border-slate-200 text-slate-400 hover:text-indigo-600 hover:border-indigo-300 hover:bg-indigo-50 transition-all shadow-sm active:scale-95 shrink-0"
            title="Listen to pronunciation"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            </svg>
          </button>
        </div>

        <div class="flex items-center justify-center gap-3 text-sm md:text-base font-mono text-slate-500 mb-8 md:mb-10">
          <span id="featured-pos" class="px-2 py-0.5 rounded border border-slate-200 bg-white font-bold text-slate-600 text-xs uppercase tracking-wider">
            </span>
          <span id="featured-phonetic" class="tracking-wide">
            </span>
        </div>

        <p id="featured-meaning" class="text-xl md:text-2xl font-bold text-slate-700 mb-3 min-h-[2rem]">
          </p>
        <p id="featured-example" class="text-base md:text-lg text-slate-500 italic max-w-2xl leading-relaxed min-h-[3rem]">
          </p>
      </div>

      <div id="action-btn" class="mt-12 md:mt-16 opacity-0 translate-y-8 transition-all duration-1000 delay-300 ease-out">
        <a 
          href="/vocabularies-common" 
          class="group relative inline-flex items-center gap-3 px-8 py-4 bg-indigo-600 text-white rounded-full font-medium transition-all duration-300 hover:scale-105 hover:bg-indigo-500 hover:shadow-[0_10px_30px_rgba(79,70,229,0.3)] animate-bounce-slow"
        >
          <span class="text-sm tracking-wider uppercase">Explore {totalWords} Words</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

    </div>

    <div id="credit-link" class="absolute bottom-6 left-0 w-full flex justify-center z-20 opacity-0 translate-y-4 transition-all duration-1000 delay-500 ease-out">
      <a 
        href="https://jeremyho.tw/" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-xs md:text-sm font-medium text-slate-400 hover:text-indigo-500 transition-colors tracking-widest uppercase flex items-center gap-1.5 md:gap-2 group"
      >
        <span class="font-sans text-slate-300 group-hover:text-indigo-300 transition-colors">© 2026</span>
        <span class="group-hover:-translate-y-0.5 transition-transform duration-300 flex items-center gap-1">Jeremy × Aira</span>
      </a>
    </div>

  </main>
</Layout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('hero-container')
  const actionBtn = document.getElementById('action-btn')
  const creditLink = document.getElementById('credit-link')
  const dataEl = document.getElementById('vocab-data')
  const ttsBtn = document.getElementById('tts-btn')
  const contentWrapper = document.getElementById('vocab-content-wrapper')

  const elWord = document.getElementById('featured-word')
  const elPos = document.getElementById('featured-pos')
  const elPhonetic = document.getElementById('featured-phonetic')
  const elMeaning = document.getElementById('featured-meaning')
  const elExample = document.getElementById('featured-example')

  let words: any[] = []
  let currentWordText = ''
  let intervalId: number | undefined

  // 渲染單字內容到畫面上
  function renderWord(vocab: any) {
    currentWordText = vocab.word
    if(elWord) elWord.textContent = vocab.word
    if(elPos) elPos.textContent = vocab.pos
    if(elPhonetic) elPhonetic.textContent = vocab.phonetic
    if(elMeaning) elMeaning.textContent = vocab.meaning
    if(elExample) elExample.textContent = `"${vocab.example}"`
  }

  // 執行切換單字動畫
  function transitionToNextWord() {
    if (words.length === 0 || !contentWrapper) return
    
    // 1. 先加上淡出與微幅位移的 class
    contentWrapper.classList.add('opacity-0', '-translate-y-2')
    
    // 2. 等待淡出動畫完成 (400ms) 後，替換文字並淡入
    setTimeout(() => {
      const randomVocab = words[Math.floor(Math.random() * words.length)]
      renderWord(randomVocab)
      
      contentWrapper.classList.remove('opacity-0', '-translate-y-2')
    }, 400) 
  }

  // 初始化資料
  if (dataEl && dataEl.dataset.words) {
    try {
      words = JSON.parse(dataEl.dataset.words)
      if (words && words.length > 0) {
        // 初始渲染第一顆單字
        const initialVocab = words[Math.floor(Math.random() * words.length)]
        renderWord(initialVocab)
        
        // 設定定時器，每 8 秒自動輪播下一個單字 (8000 毫秒)
        // eslint-disable-next-line @typescript-eslint/no-unused-vars
        intervalId = window.setInterval(transitionToNextWord, 8000)
      }
    } catch (e) {
      console.error('Failed to parse vocab data', e)
    }
  }

  // TTS 語音功能
  if (ttsBtn) {
    ttsBtn.addEventListener('click', () => {
      if (!currentWordText) return
      window.speechSynthesis.cancel() 
      const utterance = new SpeechSynthesisUtterance(currentWordText)
      utterance.lang = 'en-US' 
      utterance.rate = 0.85    
      
      ttsBtn.classList.add('scale-110', 'text-indigo-600', 'border-indigo-300', 'bg-indigo-50')
      utterance.onend = () => ttsBtn.classList.remove('scale-110', 'text-indigo-600', 'border-indigo-300', 'bg-indigo-50')
      utterance.onerror = () => ttsBtn.classList.remove('scale-110', 'text-indigo-600', 'border-indigo-300', 'bg-indigo-50')
      
      window.speechSynthesis.speak(utterance)
    })
  }

  // 畫面進場動畫
  requestAnimationFrame(() => {
    if (container) container.classList.remove('opacity-0', 'translate-y-8')
    if (actionBtn) actionBtn.classList.remove('opacity-0', 'translate-y-8')
    if (creditLink) creditLink.classList.remove('opacity-0', 'translate-y-4')
  })
})
</script>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-bounce-slow { animation: bounce-slow 4s infinite ease-in-out; }
</style>