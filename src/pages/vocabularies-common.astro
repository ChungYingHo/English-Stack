---
import Layout from '@/layouts/Layout.astro';
import { useVocabulary } from '@/utils/useVocabulary';
import VocabBoard from '@/components/Vocab/VocabBoard.svelte';

// 抓取 common 分類的單字
const vocabularies = await useVocabulary('common');
---

<Layout title="Common Vocabulary" description="High-frequency vocabulary collected from readings.">
  
  <div class="fixed top-[-20%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-indigo-100/50 blur-[120px] rounded-full pointer-events-none -z-10"></div>

  <div class="max-w-6xl mx-auto w-full px-5 md:px-8">
    <header class="text-center mb-16 animate-fade-in-up">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-800 mb-4">
        Common Vocabulary
      </h1>
      <div class="mt-6 flex justify-center gap-4 text-xs font-bold uppercase tracking-wider text-slate-400">
        <span>Total Words: {vocabularies.length}</span>
      </div>
    </header>

    <VocabBoard client:load vocabularies={vocabularies} />
    
  </div>
</Layout>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fade-in-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
</style>