---
import { generateCollectionPaths } from '@/utils/content';
import PostRenderer from '@/components/PostRenderer.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  return generateCollectionPaths('reading');
}

type Props = {
  entry: CollectionEntry<'reading'>;
}

const { entry } = Astro.props;
const isToefl = entry.slug.startsWith('toefl/');
---

<PostRenderer entry={entry} requiresAuth={isToefl} />