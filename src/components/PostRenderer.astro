---
import type { CollectionEntry } from 'astro:content';
import { AUTHORS } from '@/constants/authors';
import Layout from '@/layouts/Layout.astro';
import ToeflGuard from '@/components/ToeflGuard.svelte';

// 對齊你的 config.ts collections
interface Props {
  entry:
    | CollectionEntry<'reading'>
    | CollectionEntry<'listening'>
    | CollectionEntry<'writing'>
    | CollectionEntry<'grammar'>;
  requiresAuth?: boolean;
}

const { entry, requiresAuth = false } = Astro.props;
const { Content, headings } = await entry.render();

const authorKey = entry.data.author || 'Jeremy';
const authorData = AUTHORS.find(a => a.name.toLowerCase() === authorKey.toLowerCase()) || AUTHORS[0];

const publishDate = entry.data.date ? new Date(entry.data.date) : new Date();
const tags: string[] = (entry.data as any).tags || [];
const originalLink: string | undefined = entry.data.link;

const changelog = ((entry.data as any).changelog || [])
  .map((date: string) => new Date(date))
  .sort((a: Date, b: Date) => b.getTime() - a.getTime())
  .slice(0, 3);

const formatDate = (d: Date) => {
  if (isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
};
---

<Layout title={entry.data.title} description={entry.data.title}>

  {requiresAuth && <ToeflGuard client:load />}

  <div id="progress-bar" class="fixed top-0 left-0 h-[3px] bg-gradient-to-r from-sky-400 via-indigo-500 to-indigo-600 z-[100] w-0 transition-all duration-100 ease-out shadow-[0_0_10px_rgba(79,70,229,0.3)]"></div>
  
  <div class="fixed top-[-20%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-indigo-100/50 blur-[120px] rounded-full pointer-events-none -z-10"></div>

  <div class="relative w-full max-w-[900px] mx-auto px-5 md:px-8 pt-0 pb-0">
    
    <header class="flex flex-col items-center text-center mb-12 md:mb-16 space-y-6 animate-fade-in-up">
      {tags.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2">
          {tags.map((tag: string) => (
            <span class="px-3 py-1 text-[11px] font-bold tracking-[0.1em] uppercase rounded-full border border-slate-200 text-slate-500 bg-white shadow-sm hover:text-indigo-600 hover:border-indigo-300 transition-all duration-300">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-800 leading-[1.2] max-w-4xl mx-auto">
        {entry.data.title}
      </h1>

      <div class="flex flex-wrap items-center justify-center gap-5 text-xs font-medium text-slate-500 tracking-wider uppercase">
        <a 
          href="/about" 
          class="flex items-center gap-3 group cursor-pointer hover:opacity-90 transition-opacity p-1 -ml-1"
          title="About Author"
        >
          <img 
            src={authorData?.imgPath || '/favicon.ico'} 
            alt={authorData?.name || 'Author'} 
            class="w-10 h-10 rounded-full object-cover ring-2 ring-slate-100 group-hover:ring-indigo-200 transition-all shadow-sm" 
          />
          <span class="text-slate-500 group-hover:text-indigo-600 transition-colors border-b border-transparent group-hover:border-indigo-200 pb-0.5">
            {authorData?.name || 'Jeremy'}
          </span>
        </a>
        <div class="w-px h-4 bg-slate-300 hidden sm:block"></div>
        <div class="flex items-center gap-2" title="Published Date">
          <span class="text-slate-500">{formatDate(publishDate)}</span>
        </div>
      </div>

      {originalLink && (
        <a 
          href={originalLink} 
          target="_blank" 
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-50 hover:bg-indigo-600 text-indigo-700 hover:text-white rounded-xl transition-all duration-300 font-semibold text-sm shadow-sm border border-indigo-100 hover:border-indigo-600 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          Read Original Article
        </a>
      )}
    </header>

    <div class="relative">
      <article class="md-content min-w-0 break-words pb-24">
        <Content />

        {changelog.length > 0 && (
          <div class="mt-24 pt-8 border-t border-slate-200">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6">Latest Updates</h3>
            <ul class="space-y-3">
              {changelog.map((date: Date) => (
                <li class="flex items-center gap-4 text-xs text-slate-500 group">
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 group-hover:bg-indigo-600 transition-colors"></span>
                  <span class="font-mono text-slate-400">{formatDate(date)}</span>
                  <span class="text-slate-600 group-hover:text-slate-900 transition-colors">Content updated</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </article>

      {headings.length > 0 && (
        <aside class="hidden xl:block absolute top-0 left-[100%] ml-12 h-full">
          <div class="sticky top-32 w-60 max-h-[75vh] overflow-y-auto custom-scrollbar">
            <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-4 pl-3 border-l-2 border-transparent">
              On this page
            </div>
            <nav>
              <ul class="space-y-0.5">
                {headings.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class="toc-link block py-1.5 pl-3 border-l-2 border-slate-100 text-xs text-slate-400 hover:text-indigo-600 hover:border-indigo-400 transition-all duration-200 truncate leading-relaxed"
                      data-depth={heading.depth}
                      style={`margin-left: ${(heading.depth - 2) * 0.5}rem`}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>

  {headings.length > 0 && (
    <div
      id="mobile-toc-container"
      class="xl:hidden fixed z-50 bottom-0 left-0 right-0 translate-y-[calc(100%-4rem)] transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] border-t border-slate-200 bg-white/95 backdrop-blur-xl shadow-[0_-10px_40px_rgba(0,0,0,0.08)]"
    >
      <button id="toc-toggle" class="w-full h-16 flex items-center justify-between px-6 cursor-pointer group">
        <div class="flex flex-col items-start">
          <span class="text-xs font-bold tracking-[0.2em] text-slate-700 uppercase group-hover:text-indigo-600 transition-colors">Table of Contents</span>
          <span class="text-[10px] text-slate-400 mt-0.5" id="toc-hint">Click to expand</span>
        </div>
        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center group-hover:bg-indigo-50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-500 group-hover:text-indigo-600 transition-all duration-300" id="toc-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
          </svg>
        </div>
      </button>
      <div class="px-6 py-6 pb-16 max-h-[60vh] overflow-y-auto custom-scrollbar">
        <ul class="space-y-2">
          {headings.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class="mobile-toc-link block text-sm text-slate-500 hover:text-indigo-600 transition-colors border-l-2 border-transparent pl-4 hover:border-indigo-400"
                style={`margin-left: ${(heading.depth - 1) * 0.5}rem`}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  )}
</Layout>

<script>
// === 1. Progress Bar ===
const progressBar = document.getElementById('progress-bar')
window.addEventListener('scroll', () => {
  if(progressBar) {
    const winScroll = document.documentElement.scrollTop
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight
    const scrolled = height > 0 ? (winScroll / height) * 100 : 0
    progressBar.style.width = scrolled + '%'
  }
})

// === 2. TOC Highlight ===
const tocObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      document.querySelectorAll('.toc-link').forEach(l => {
        l.classList.remove('text-indigo-600', 'border-indigo-400')
        l.classList.add('text-slate-400', 'border-slate-100')
      })
      const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`)
      if (activeLink) {
        activeLink.classList.remove('text-slate-400', 'border-slate-100')
        activeLink.classList.add('text-indigo-600', 'border-indigo-400')
      }
    }
  })
}, { rootMargin: '-100px 0px -70% 0px' })
document.querySelectorAll('.md-content h2, .md-content h3').forEach(h => tocObserver.observe(h))

// === 3. Mobile TOC Toggle ===
const tocToggleBtn = document.getElementById('toc-toggle')
const tocContainer = document.getElementById('mobile-toc-container')
const tocIcon = document.getElementById('toc-icon')
const tocHint = document.getElementById('toc-hint')
let tocIsOpen = false

const toggleToc = (force?: boolean) => {
  tocIsOpen = force ?? !tocIsOpen
  if (tocIsOpen) {
    tocContainer?.classList.remove('translate-y-[calc(100%-4rem)]')
    tocContainer?.classList.add('translate-y-0')
    tocIcon?.classList.add('rotate-180')
    if (tocHint) tocHint.innerText = 'Click to close'
  } else {
    tocContainer?.classList.add('translate-y-[calc(100%-4rem)]')
    tocContainer?.classList.remove('translate-y-0')
    tocIcon?.classList.remove('rotate-180')
    if (tocHint) tocHint.innerText = 'Click to expand'
  }
}

tocToggleBtn?.addEventListener('click', () => toggleToc())
document.querySelectorAll('.mobile-toc-link').forEach(l => l.addEventListener('click', () => toggleToc(false)))

// === 4. Code Block Copy Button + Heading Anchors + External Links + TTS ===
document.addEventListener('DOMContentLoaded', () => {
  const preElements = document.querySelectorAll('pre')

  preElements.forEach(pre => {
    const wrapper = document.createElement('div')
    wrapper.className = 'code-block-wrapper group relative mb-8 rounded-xl overflow-hidden shadow-sm border border-slate-200'
    
    pre.parentNode?.insertBefore(wrapper, pre)
    wrapper.appendChild(pre)

    pre.style.marginTop = '0'
    pre.style.marginBottom = '0'
    pre.style.borderRadius = '0'

    const copyBtn = document.createElement('button')
    copyBtn.className = 'copy-btn'
    copyBtn.setAttribute('aria-label', 'Copy code')
    
    copyBtn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    `

    copyBtn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText || ''
      try {
        await navigator.clipboard.writeText(code)
        copyBtn.classList.add('is-copied')
        setTimeout(() => copyBtn.classList.remove('is-copied'), 2000)
      } catch (err) {
        console.error('Failed to copy!', err)
      }
    })

    wrapper.appendChild(copyBtn)
  })

  // === 5. Heading Anchor Links ===
  const headings = document.querySelectorAll('.md-content h1, .md-content h2, .md-content h3')
  headings.forEach(heading => {
    const anchor = document.createElement('a')
    anchor.className = 'heading-anchor'
    anchor.href = `#${heading.id}`
    anchor.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
      </svg>
    `
    
    anchor.addEventListener('click', (e) => {
      e.preventDefault()
      history.pushState(null, '', anchor.href)
      navigator.clipboard.writeText(window.location.href)
      
      anchor.classList.add('copied')
      setTimeout(() => anchor.classList.remove('copied'), 1500)
    })

    heading.appendChild(anchor)
  })

  // === 6. External Links ===
  const contentLinks = document.querySelectorAll('.md-content a')
  contentLinks.forEach(link => {
    const href = link.getAttribute('href')
    if (href && !href.startsWith('#')) {
      link.setAttribute('target', '_blank')
      link.setAttribute('rel', 'noopener noreferrer')
    }
  })

  // === 7. Vocabulary TTS ===
  const vocabRows = document.querySelectorAll('.md-content table tbody tr')
  
  vocabRows.forEach(row => {
    const wordTd = row.querySelector('td:nth-child(1)')
    if (!wordTd) return
    
    const wordText = wordTd.textContent?.trim() || ''
    
    const ttsBtn = document.createElement('button')
    ttsBtn.className = 'vocab-tts-btn'
    ttsBtn.setAttribute('title', 'Listen to pronunciation')
    ttsBtn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
      </svg>
    `
    
    ttsBtn.addEventListener('click', (e) => {
      e.preventDefault()
      window.speechSynthesis.cancel() 
      
      const utterance = new SpeechSynthesisUtterance(wordText)
      utterance.lang = 'en-US' 
      utterance.rate = 0.85    
      
      ttsBtn.classList.add('playing')
      utterance.onend = () => ttsBtn.classList.remove('playing')
      utterance.onerror = () => ttsBtn.classList.remove('playing')
      
      window.speechSynthesis.speak(utterance)
    })
    
    wordTd.appendChild(ttsBtn)
  })
})
</script>

<style is:global>
  /* Base Typography */
  .md-content { color: #334155; font-size: 1.05rem; line-height: 1.8; letter-spacing: 0.01em; }
  @media (min-width: 768px) { .md-content { font-size: 1.125rem; line-height: 1.9; } }
  .md-content strong { color: #0f172a; font-weight: 600; }
  
  /* Headings */
  .md-content h1, .md-content h2, .md-content h3, .md-content h4 { color: #0f172a; font-weight: 700; line-height: 1.3; scroll-margin-top: 6rem; position: relative; }
  
  /* Anchor Links */
  .heading-anchor { display: inline-flex; align-items: center; justify-content: center; margin-left: 0.5rem; opacity: 0; color: #94a3b8; transition: all 0.2s; vertical-align: middle; cursor: pointer; }
  .md-content h1:hover .heading-anchor, .md-content h2:hover .heading-anchor, .md-content h3:hover .heading-anchor { opacity: 1; }
  .heading-anchor:hover { color: #4f46e5; }
  .heading-anchor.copied { color: #10b981; transform: scale(1.1); }

  .md-content h1 { display: block; font-size: 2.25rem; text-align: center; margin-top: 4rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid #e2e8f0; }
  @media (min-width: 768px) { .md-content h1 { font-size: 3rem; } }
  
  .md-content h2 { font-size: 1.75rem; margin-top: 5rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e2e8f0; }
  @media (min-width: 768px) { .md-content h2 { font-size: 2rem; margin-top: 7rem; } }
  
  .md-content h3 { font-size: 1.35rem; margin-top: 3.5rem; margin-bottom: 1rem; padding-left: 0.75rem; border-left: 4px solid #6366f1; }
  @media (min-width: 768px) { .md-content h3 { font-size: 1.5rem; margin-top: 4.5rem; padding-left: 1rem; } }

  .md-content h4 { font-size: 1.15rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.75rem; color: #475569; }

  /* Paragraphs & Lists */
  .md-content p { margin-bottom: 1.5rem; }
  .md-content ul { list-style: disc; }
  .md-content ol { list-style: decimal; }
  .md-content ul, .md-content ol { margin: 1.5rem 0; padding-left: 1.25rem; }
  @media (min-width: 768px) { .md-content ul, .md-content ol { padding-left: 1.5rem; } }
  .md-content li { margin: 0.5rem 0; padding-left: 0.25rem; }
  .md-content li::marker { color: #94a3b8; }

  /* Links */
  .md-content a { color: #4f46e5; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .md-content a:hover { border-bottom-color: #4f46e5; }
  
  /* Blockquote */
  .md-content blockquote { margin: 3rem 0; padding: 2rem; text-align: center; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; color: #64748b; font-family: "Georgia", "Times New Roman", serif; font-style: italic; font-size: 1.15rem; line-height: 1.8; }
  .md-content blockquote p { margin-bottom: 0; }

  /* Inline Code */
  .md-content :not(pre) > code { font-family: 'Inter', system-ui, sans-serif; font-size: 0.9em; color: #4338ca; background: #e0e7ff; padding: 0.15rem 0.5rem; border-radius: 0.375rem; font-weight: 600; }
  
  /* === Vocabulary Cards Styles === */
  .md-content table { display: grid; grid-template-columns: 1fr; gap: 1.25rem; width: 100%; border: none; margin: 3rem 0; }
  @media (min-width: 768px) { .md-content table { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); } }
  
  .md-content thead { display: none; } 
  .md-content tbody { display: contents; } 
  
  .md-content tr { display: flex; flex-direction: column; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 1rem; padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); transition: transform 0.2s, box-shadow 0.2s; }
  .md-content tr:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); border-color: #cbd5e1; }
  
  .md-content td { border: none !important; padding: 0; background: transparent !important; }

  /* 第一欄：單字 (加上 Flex 讓按鈕靠右) */
  .md-content td:nth-child(1) { 
    font-size: 1.35rem; 
    font-weight: 800; 
    color: #4f46e5; 
    margin-bottom: 0.25rem; 
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  /* 第二至第五欄：音標、詞性、中文、例句 */
  .md-content td:nth-child(2) { font-size: 0.85rem; color: #64748b; font-family: 'JetBrains Mono', monospace; margin-bottom: 0.75rem; }
  .md-content td:nth-child(3) { align-self: flex-start; display: inline-flex; align-items: center; background: #f1f5f9; color: #475569; font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 9999px; margin-bottom: 1rem; }
  .md-content td:nth-child(4) { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin-bottom: 0.75rem; }
  .md-content td:nth-child(5) { font-size: 0.95rem; color: #475569; line-height: 1.6; border-top: 1px dashed #e2e8f0; padding-top: 1rem; margin-top: auto; font-style: italic; }

  /* === TTS Button Styles === */
  .vocab-tts-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: #94a3b8; 
    background: #f8fafc; 
    border: 1px solid #e2e8f0;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .vocab-tts-btn:hover {
    color: #4f46e5; 
    background: #e0e7ff; 
    border-color: #c7d2fe; 
    transform: scale(1.05);
  }
  
  /* 播放中的按鈕狀態 */
  .vocab-tts-btn.playing {
    color: #10b981; 
    background: #d1fae5; 
    border-color: #6ee7b7; 
    animation: pulse-ring 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  /* Code Blocks */
  .md-content pre { padding: 1.25rem; background: #0f172a; border-radius: 0.75rem; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; }
  .md-content pre code { background: transparent; padding: 0; color: inherit; font-weight: 400; }

  .md-content img { border-radius: 0.75rem; border: 1px solid #e2e8f0; margin: 3rem auto; display: block; max-width: 100%; height: auto; }
  .md-content hr { border: 0; height: 1px; background: #e2e8f0; margin: 4rem 0; }

  /* Scrollbar */
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* Copy Button */
  .copy-btn { position: absolute; top: 0.5rem; right: 0.5rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 0.5rem; background-color: rgba(255, 255, 255, 0.1); color: #94a3b8; transition: all 0.2s; opacity: 0; z-index: 20; border: 1px solid rgba(255,255,255,0.1); }
  .code-block-wrapper:hover .copy-btn { opacity: 1; }
  .copy-btn:hover { background-color: rgba(255, 255, 255, 0.2); color: #fff; }
  .copy-btn.is-copied { border-color: rgba(16, 185, 129, 0.3); background-color: rgba(16, 185, 129, 0.15); color: #10b981; }
  .copy-btn .icon-check { display: none; }
  .copy-btn .icon-copy { display: block; }
  .copy-btn.is-copied .icon-check { display: block; }
